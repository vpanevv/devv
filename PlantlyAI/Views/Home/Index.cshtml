@model BrandSetupViewModel

@{
    ViewData["Title"] = "Plantly AI";
    var openBrandDialog = ViewData["OpenBrandDialog"] as bool? ?? false;
    var openLoginDialog = ViewData["OpenLoginDialog"] as bool? ?? false;
    var loginError = ViewData["LoginError"] as string;
    var loginEmail = ViewData["LoginEmail"] as string;
    var statusMessage = TempData["StatusMessage"] as string;
    var openSuccessDialog = TempData["OpenSuccessDialog"] as bool? ?? false;
}

<section class="hero-shell">
    <div class="hero-background" aria-hidden="true">
        <span class="orb orb-one"></span>
        <span class="orb orb-two"></span>
        <span class="orb orb-three"></span>
        <span class="orb orb-four"></span>
        <span class="orb orb-five"></span>
        <span class="orb orb-six"></span>
        <span class="spark spark-one"></span>
        <span class="spark spark-two"></span>
        <span class="spark spark-three"></span>
        <span class="spark spark-four"></span>
        <span class="spark spark-five"></span>
        <span class="spark spark-six"></span>
        <span class="spark spark-seven"></span>
        <span class="spark spark-eight"></span>
        <span class="halo-ring halo-ring-one"></span>
        <span class="halo-ring halo-ring-two"></span>
        <span class="data-stream data-stream-one"></span>
        <span class="data-stream data-stream-two"></span>
        <span class="grid-glow"></span>
    </div>

    <div class="topbar">
        <div class="brand-mark" aria-label="Plantly AI logo">
            <span class="brand-icon">
                <span class="brand-core"></span>
                <span class="brand-leaf brand-leaf-one"></span>
                <span class="brand-leaf brand-leaf-two"></span>
            </span>
            <span class="brand-text">Plantly AI</span>
        </div>

        <div class="signal-panel" aria-label="Current date and time">
            <span class="signal-label">AI SYSTEM TIME</span>
            <span class="signal-date" data-current-date></span>
            <span class="signal-time" data-current-time></span>
        </div>
    </div>

    <div class="hero-content">
        @if (!string.IsNullOrWhiteSpace(statusMessage) && !openSuccessDialog)
        {
            <div class="status-toast">@statusMessage</div>
        }

        <p class="hero-eyebrow">AI CONTENT PLANNER FOR BUSINESSES</p>

        <div class="hero-card">
            <h1>Plantly AI</h1>
            <p class="hero-copy">
                Plan campaigns, organize your posting calendar, and grow a brand presence with an AI-first workflow.
            </p>
            <div class="hero-actions">
                <button class="hero-cta" type="button" aria-label="Sign in to Plantly AI" data-open-brand-dialog>
                    SIGN IN
                </button>
                <button class="hero-cta hero-cta-secondary" type="button" aria-label="Log in to Plantly AI" data-open-login-dialog>
                    LOG IN
                </button>
            </div>
        </div>
    </div>

    <button class="services-cta" type="button" data-open-services-dialog>
        OUR SERVICES
    </button>

    <div class="services-dialog-backdrop" data-services-dialog hidden>
        <div class="services-dialog" role="dialog" aria-modal="true" aria-labelledby="services-dialog-title">
            <div class="services-dialog-background" aria-hidden="true">
                <span class="dialog-orb dialog-orb-one"></span>
                <span class="dialog-orb dialog-orb-two"></span>
                <span class="dialog-orb dialog-orb-three"></span>
                <span class="dialog-spark dialog-spark-one"></span>
                <span class="dialog-spark dialog-spark-two"></span>
                <span class="dialog-spark dialog-spark-three"></span>
                <span class="dialog-spark dialog-spark-four"></span>
            </div>

            <button class="services-close" type="button" aria-label="Close services dialog" data-close-services-dialog>
                X
            </button>

            <div class="services-dialog-content">
                <h2 id="services-dialog-title">What Plantly AI Does</h2>

                <div class="services-grid">
                    <article class="service-card">
                        <h3>AI POST IDEAS</h3>
                        <p>
                            Generate fresh post angles for promotions, launches, seasonal moments, and daily engagement.
                            The system helps small businesses avoid repetitive content and keep ideas flowing every week.
                        </p>
                    </article>

                    <article class="service-card">
                        <h3>SOCIAL MEDIA CONTENT</h3>
                        <p>
                            Build captions, hashtags, and platform-ready content in a faster workflow. Plantly AI helps turn
                            a single idea into usable posts that still feel aligned with your brand voice.
                        </p>
                    </article>

                    <article class="service-card">
                        <h3>BRAND GROWING</h3>
                        <p>
                            Use AI-driven insights to spot what content themes are working and where your audience reacts most.
                            This makes it easier for growing businesses to stay consistent and improve visibility over time.
                        </p>
                    </article>

                    <article class="service-card">
                        <h3>CALENDAR/DASHBOARD</h3>
                        <p>
                            Manage campaigns, monthly plans, and posting schedules from one clear workspace. The dashboard is
                            built to keep your content organized while giving a fast overview of what is planned next.
                        </p>
                    </article>
                </div>
            </div>
        </div>
    </div>

    <div class="services-dialog-backdrop" data-brand-dialog hidden="@(openBrandDialog ? null : "hidden")">
        <div class="services-dialog brand-dialog" role="dialog" aria-modal="true" aria-labelledby="brand-dialog-title">
            <div class="services-dialog-background" aria-hidden="true">
                <span class="dialog-orb dialog-orb-one"></span>
                <span class="dialog-orb dialog-orb-two"></span>
                <span class="dialog-orb dialog-orb-three"></span>
                <span class="dialog-spark dialog-spark-one"></span>
                <span class="dialog-spark dialog-spark-two"></span>
                <span class="dialog-spark dialog-spark-three"></span>
                <span class="dialog-spark dialog-spark-four"></span>
            </div>

            <button class="services-close" type="button" aria-label="Close sign in dialog" data-close-brand-dialog>
                X
            </button>

            <div class="services-dialog-content">
                <div class="brand-dialog-header">
                    <p class="brand-dialog-kicker">Create your business workspace</p>
                    <h2 id="brand-dialog-title">Set Up Plantly AI For Your Brand</h2>
                    <p class="brand-dialog-copy">
                        Start with the essentials your business needs so Plantly AI can build smarter content plans,
                        stronger brand guidance, and a more useful dashboard from day one.
                    </p>
                </div>

                <form asp-action="CreateWorkspace" asp-controller="Home" method="post" class="brand-form" enctype="multipart/form-data" novalidate data-brand-form>
                    <div asp-validation-summary="ModelOnly" class="validation-panel"></div>

                    <div class="brand-section-card">
                        <div class="brand-section-heading">
                            <span class="brand-section-step">01</span>
                            <div>
                                <h3>Basic Brand Information</h3>
                                <p>The core identity of the brand.</p>
                            </div>
                        </div>

                        <div class="brand-form-grid">
                            <label class="field-group field-group-full">
                                <span class="field-label">Business Email <strong>*</strong></span>
                                <input asp-for="Email" type="email" placeholder="founder@yourbrand.com" required />
                            </label>

                            <label class="field-group">
                                <span class="field-label">Brand Name <strong>*</strong></span>
                                <input asp-for="BrandName" type="text" placeholder="Plantly Coffee Studio" required />
                            </label>

                            <label class="field-group">
                                <span class="field-label">Industry</span>
                                <select asp-for="Industry">
                                    <option value="">Select industry</option>
                                    <option>Restaurant</option>
                                    <option>Tech</option>
                                    <option>Fashion</option>
                                    <option>Beauty</option>
                                    <option>Fitness</option>
                                    <option>Wellness</option>
                                    <option>Real Estate</option>
                                    <option>Education</option>
                                    <option>Other</option>
                                </select>
                            </label>

                            <label class="field-group">
                                <span class="field-label">Website URL</span>
                                <input asp-for="WebsiteUrl" type="url" placeholder="https://yourbrand.com" />
                            </label>

                            <div class="field-group">
                                <span class="field-label">Business Location</span>
                                <div class="map-picker">
                                    <div class="map-surface">
                                        <span class="map-grid"></span>
                                        <span class="map-pin map-pin-one"></span>
                                        <span class="map-pin map-pin-two"></span>
                                        <span class="map-pin map-pin-three"></span>
                                    </div>
                                    <div class="map-actions">
                                        <button class="map-chip" type="button" data-map-choice="Sofia">Sofia</button>
                                        <button class="map-chip" type="button" data-map-choice="London">London</button>
                                        <button class="map-chip" type="button" data-map-choice="New York">New York</button>
                                        <button class="map-chip" type="button" data-map-choice="Paris">Paris</button>
                                        <button class="map-chip" type="button" data-map-choice="Berlin">Berlin</button>
                                        <button class="map-chip" type="button" data-map-choice="Dubai">Dubai</button>
                                        <button class="map-chip" type="button" data-map-choice="Tokyo">Tokyo</button>
                                        <button class="map-chip" type="button" data-map-choice="Los Angeles">Los Angeles</button>
                                    </div>
                                    <div class="location-picker-grid">
                                        <select data-map-location-select>
                                            <option value="">Choose a city</option>
                                            <option selected="@(Model.BusinessLocation == "Sofia" ? "selected" : null)">Sofia</option>
                                            <option selected="@(Model.BusinessLocation == "London" ? "selected" : null)">London</option>
                                            <option selected="@(Model.BusinessLocation == "New York" ? "selected" : null)">New York</option>
                                            <option selected="@(Model.BusinessLocation == "Paris" ? "selected" : null)">Paris</option>
                                            <option selected="@(Model.BusinessLocation == "Berlin" ? "selected" : null)">Berlin</option>
                                            <option selected="@(Model.BusinessLocation == "Dubai" ? "selected" : null)">Dubai</option>
                                            <option selected="@(Model.BusinessLocation == "Tokyo" ? "selected" : null)">Tokyo</option>
                                            <option selected="@(Model.BusinessLocation == "Los Angeles" ? "selected" : null)">Los Angeles</option>
                                            <option selected="@(Model.BusinessLocation == "Barcelona" ? "selected" : null)">Barcelona</option>
                                            <option selected="@(Model.BusinessLocation == "Amsterdam" ? "selected" : null)">Amsterdam</option>
                                        </select>
                                        <input asp-for="BusinessLocation" type="text" placeholder="Selected city or custom location" data-map-location-input />
                                    </div>
                                </div>
                            </div>

                            <label class="field-group">
                                <span class="field-label">Logo Upload</span>
                                <span class="upload-panel" data-logo-upload-panel>
                                    <span class="upload-background" aria-hidden="true">
                                        <span class="upload-orb upload-orb-one"></span>
                                        <span class="upload-orb upload-orb-two"></span>
                                        <span class="upload-grid"></span>
                                    </span>
                                    <span class="upload-content">
                                        <span class="upload-badge">Future-ready brand identity</span>
                                        <span class="upload-title">Drop your logo or browse files</span>
                                        <span class="upload-copy">Prepare your workspace for AI visuals, branded templates, and polished content outputs.</span>
                                        <span class="upload-button" data-logo-upload-status aria-live="polite">Choose Logo File</span>
                                    </span>
                                    <input asp-for="LogoFile" class="upload-input" type="file" accept="image/*" data-logo-upload-input />
                                </span>
                            </label>

                            <label class="field-group field-group-full">
                                <span class="field-label">Short Description</span>
                                <textarea asp-for="ShortDescription" rows="3" placeholder="Describe what your business does and what makes it different."></textarea>
                            </label>
                        </div>
                    </div>

                    <div class="brand-section-card">
                        <div class="brand-section-heading">
                            <span class="brand-section-step">02</span>
                            <div>
                                <h3>Social Media Presence</h3>
                                <p>Primary platforms and publishing rhythm.</p>
                            </div>
                        </div>

                        <div class="brand-form-grid">
                            <fieldset class="field-group field-group-full">
                                <legend class="field-label">Primary Platforms</legend>
                                <div class="check-grid">
                                    <label class="choice-pill"><input type="checkbox" name="SelectedPlatforms" value="Instagram" data-platform-toggle="instagram" checked="@(Model.SelectedPlatforms.Contains("Instagram") ? "checked" : null)" /> Instagram</label>
                                    <label class="choice-pill"><input type="checkbox" name="SelectedPlatforms" value="Facebook" data-platform-toggle="facebook" checked="@(Model.SelectedPlatforms.Contains("Facebook") ? "checked" : null)" /> Facebook</label>
                                    <label class="choice-pill"><input type="checkbox" name="SelectedPlatforms" value="LinkedIn" data-platform-toggle="linkedin" checked="@(Model.SelectedPlatforms.Contains("LinkedIn") ? "checked" : null)" /> LinkedIn</label>
                                    <label class="choice-pill"><input type="checkbox" name="SelectedPlatforms" value="TikTok" data-platform-toggle="tiktok" checked="@(Model.SelectedPlatforms.Contains("TikTok") ? "checked" : null)" /> TikTok</label>
                                </div>
                            </fieldset>

                            <label class="field-group">
                                <span class="field-label">Instagram Link</span>
                                <input asp-for="InstagramUrl" type="url" placeholder="https://instagram.com/yourbrand" data-platform-link="instagram" />
                            </label>

                            <label class="field-group">
                                <span class="field-label">Facebook Link</span>
                                <input asp-for="FacebookUrl" type="url" placeholder="https://facebook.com/yourbrand" data-platform-link="facebook" />
                            </label>

                            <label class="field-group">
                                <span class="field-label">LinkedIn Link</span>
                                <input asp-for="LinkedInUrl" type="url" placeholder="https://linkedin.com/company/yourbrand" data-platform-link="linkedin" />
                            </label>

                            <label class="field-group">
                                <span class="field-label">TikTok Link</span>
                                <input asp-for="TikTokUrl" type="url" placeholder="https://tiktok.com/yourbrand" data-platform-link="tiktok" />
                            </label>

                            <fieldset class="field-group field-group-full">
                                <legend class="field-label">Posting Frequency Goal</legend>
                                <div class="frequency-selector">
                                    <button class="frequency-option" type="button" data-frequency-choice="1 post/week">1 / week</button>
                                    <button class="frequency-option" type="button" data-frequency-choice="2 posts/week">2 / week</button>
                                    <button class="frequency-option" type="button" data-frequency-choice="3 posts/week">3 / week</button>
                                    <button class="frequency-option" type="button" data-frequency-choice="5 posts/week">5 / week</button>
                                    <button class="frequency-option" type="button" data-frequency-choice="7 posts/week">Daily</button>
                                </div>
                                <input asp-for="PostingFrequencyGoal" type="hidden" data-frequency-input />
                            </fieldset>
                        </div>
                    </div>

                    <div class="brand-section-card">
                        <div class="brand-section-heading">
                            <span class="brand-section-step">03</span>
                            <div>
                                <h3>Target Audience</h3>
                                <p>Helps with planning and AI generation.</p>
                            </div>
                        </div>

                        <div class="brand-form-grid">
                            <fieldset class="field-group field-group-full">
                                <legend class="field-label">Age Range Choice</legend>
                                <div class="check-grid">
                                    <label class="choice-pill"><input asp-for="AgeRange" type="radio" value="18-24" checked="@(Model.AgeRange == "18-24" ? "checked" : null)" /> 18-24</label>
                                    <label class="choice-pill"><input asp-for="AgeRange" type="radio" value="25-34" checked="@(Model.AgeRange == "25-34" ? "checked" : null)" /> 25-34</label>
                                    <label class="choice-pill"><input asp-for="AgeRange" type="radio" value="35-44" checked="@(Model.AgeRange == "35-44" ? "checked" : null)" /> 35-44</label>
                                    <label class="choice-pill"><input asp-for="AgeRange" type="radio" value="45+" checked="@(Model.AgeRange == "45+" ? "checked" : null)" /> 45+</label>
                                </div>
                            </fieldset>
                        </div>
                    </div>

                    <div class="brand-section-card">
                        <div class="brand-section-heading">
                            <span class="brand-section-step">04</span>
                            <div>
                                <h3>Brand Voice</h3>
                                <p>The most important section for AI guidance.</p>
                            </div>
                        </div>

                        <div class="brand-form-grid">
                            <fieldset class="field-group field-group-full">
                                <legend class="field-label">Brand Voice</legend>
                                <div class="check-grid">
                                    <label class="choice-pill"><input type="checkbox" name="BrandVoices" value="Professional" checked="@(Model.BrandVoices.Contains("Professional") ? "checked" : null)" /> Professional</label>
                                    <label class="choice-pill"><input type="checkbox" name="BrandVoices" value="Friendly" checked="@(Model.BrandVoices.Contains("Friendly") ? "checked" : null)" /> Friendly</label>
                                    <label class="choice-pill"><input type="checkbox" name="BrandVoices" value="Luxury" checked="@(Model.BrandVoices.Contains("Luxury") ? "checked" : null)" /> Luxury</label>
                                    <label class="choice-pill"><input type="checkbox" name="BrandVoices" value="Playful" checked="@(Model.BrandVoices.Contains("Playful") ? "checked" : null)" /> Playful</label>
                                    <label class="choice-pill"><input type="checkbox" name="BrandVoices" value="Minimal" checked="@(Model.BrandVoices.Contains("Minimal") ? "checked" : null)" /> Minimal</label>
                                    <label class="choice-pill"><input type="checkbox" name="BrandVoices" value="Bold" checked="@(Model.BrandVoices.Contains("Bold") ? "checked" : null)" /> Bold</label>
                                    <label class="choice-pill"><input type="checkbox" name="BrandVoices" value="Inspirational" checked="@(Model.BrandVoices.Contains("Inspirational") ? "checked" : null)" /> Inspirational</label>
                                </div>
                            </fieldset>
                        </div>
                    </div>

                    <div class="brand-section-card">
                        <div class="brand-section-heading">
                            <span class="brand-section-step">05</span>
                            <div>
                                <h3>Content Goals</h3>
                                <p>Define the main business outcome you want from your content.</p>
                            </div>
                        </div>

                        <div class="brand-form-grid">
                            <fieldset class="field-group field-group-full">
                                <legend class="field-label">Main Goal</legend>
                                <div class="check-grid">
                                    <label class="choice-pill"><input asp-for="MainGoal" type="radio" value="Brand Awareness" checked="@(Model.MainGoal == "Brand Awareness" ? "checked" : null)" /> Brand Awareness</label>
                                    <label class="choice-pill"><input asp-for="MainGoal" type="radio" value="Engagement" checked="@(Model.MainGoal == "Engagement" ? "checked" : null)" /> Engagement</label>
                                    <label class="choice-pill"><input asp-for="MainGoal" type="radio" value="Sales" checked="@(Model.MainGoal == "Sales" ? "checked" : null)" /> Sales</label>
                                    <label class="choice-pill"><input asp-for="MainGoal" type="radio" value="Community Growth" checked="@(Model.MainGoal == "Community Growth" ? "checked" : null)" /> Community Growth</label>
                                </div>
                            </fieldset>
                        </div>
                    </div>

                    <div class="brand-form-actions">
                        <p><strong>*</strong> Required for the initial sign-in flow.</p>
                        <button class="workspace-cta" type="submit">CREATE WORKSPACE</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="services-dialog-backdrop" data-login-dialog hidden="@(openLoginDialog ? null : "hidden")">
        <div class="services-dialog login-dialog" role="dialog" aria-modal="true" aria-labelledby="login-dialog-title">
            <div class="services-dialog-background" aria-hidden="true">
                <span class="dialog-orb dialog-orb-one"></span>
                <span class="dialog-orb dialog-orb-two"></span>
                <span class="dialog-orb dialog-orb-three"></span>
                <span class="dialog-spark dialog-spark-one"></span>
                <span class="dialog-spark dialog-spark-two"></span>
                <span class="dialog-spark dialog-spark-three"></span>
                <span class="dialog-spark dialog-spark-four"></span>
            </div>

            <button class="services-close" type="button" aria-label="Close log in dialog" data-close-login-dialog>
                X
            </button>

            <div class="services-dialog-content">
                <div class="brand-dialog-header">
                    <p class="brand-dialog-kicker">Log in to your workspace</p>
                    <h2 id="login-dialog-title">Continue with your business email</h2>
                    <p class="brand-dialog-copy">
                        Use the same email address you used when creating the workspace.
                    </p>
                </div>

                <form asp-action="LogIn" asp-controller="Home" method="post" class="brand-form login-form">
                    @Html.AntiForgeryToken()

                    @if (!string.IsNullOrWhiteSpace(loginError))
                    {
                        <div class="validation-panel validation-panel-inline">
                            <ul>
                                <li>@loginError</li>
                            </ul>
                        </div>
                    }

                    <label class="field-group field-group-full">
                        <span class="field-label">Business Email <strong>*</strong></span>
                        <input name="email" type="email" value="@loginEmail" placeholder="founder@yourbrand.com" required />
                    </label>

                    <div class="brand-form-actions login-form-actions">
                        <button class="workspace-cta" type="submit">LOG IN</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="services-dialog-backdrop" data-success-dialog hidden="@(openSuccessDialog ? null : "hidden")">
        <div class="services-dialog success-dialog" role="dialog" aria-modal="true" aria-labelledby="success-dialog-title">
            <div class="services-dialog-background" aria-hidden="true">
                <span class="dialog-orb dialog-orb-one"></span>
                <span class="dialog-orb dialog-orb-two"></span>
                <span class="dialog-orb dialog-orb-three"></span>
                <span class="dialog-spark dialog-spark-one"></span>
                <span class="dialog-spark dialog-spark-two"></span>
                <span class="dialog-spark dialog-spark-three"></span>
            </div>

            <button class="services-close" type="button" aria-label="Close success dialog" data-close-success-dialog>
                X
            </button>

            <div class="services-dialog-content success-dialog-content">
                <p class="brand-dialog-kicker">Workspace ready</p>
                <h2 id="success-dialog-title">The workspace is created</h2>
                <p class="brand-dialog-copy">
                    The form data has been saved, and this popup is here for testing the successful flow.
                </p>
            </div>
        </div>
    </div>
</section>

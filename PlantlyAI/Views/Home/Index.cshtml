@{
    ViewData["Title"] = "Plantly AI";
}

<section class="hero-shell">
    <div class="hero-background" aria-hidden="true">
        <span class="orb orb-one"></span>
        <span class="orb orb-two"></span>
        <span class="orb orb-three"></span>
        <span class="orb orb-four"></span>
        <span class="orb orb-five"></span>
        <span class="orb orb-six"></span>
        <span class="spark spark-one"></span>
        <span class="spark spark-two"></span>
        <span class="spark spark-three"></span>
        <span class="spark spark-four"></span>
        <span class="spark spark-five"></span>
        <span class="spark spark-six"></span>
        <span class="spark spark-seven"></span>
        <span class="spark spark-eight"></span>
        <span class="halo-ring halo-ring-one"></span>
        <span class="halo-ring halo-ring-two"></span>
        <span class="data-stream data-stream-one"></span>
        <span class="data-stream data-stream-two"></span>
        <span class="grid-glow"></span>
    </div>

    <div class="topbar">
        <div class="brand-mark" aria-label="Plantly AI logo">
            <span class="brand-icon">
                <span class="brand-core"></span>
                <span class="brand-leaf brand-leaf-one"></span>
                <span class="brand-leaf brand-leaf-two"></span>
            </span>
            <span class="brand-text">Plantly AI</span>
        </div>

        <div class="signal-panel" aria-label="Current date and time">
            <span class="signal-label">AI SYSTEM TIME</span>
            <span class="signal-date" data-current-date></span>
            <span class="signal-time" data-current-time></span>
        </div>
    </div>

    <div class="hero-content">
        <p class="hero-eyebrow">AI CONTENT PLANNER FOR BUSINESSES</p>

        <div class="hero-card">
            <h1>Plantly AI</h1>
            <p class="hero-copy">
                Plan campaigns, organize your posting calendar, and grow a brand presence with an AI-first workflow.
            </p>
            <div class="hero-actions">
                <a class="hero-cta" href="#" role="button" aria-label="Sign in to Plantly AI">
                    SIGN IN
                </a>
                <a class="hero-cta" href="#" role="button" aria-label="Log in to Plantly AI">
                    LOG IN
                </a>
            </div>
        </div>
    </div>

    <button class="services-cta" type="button" data-open-services-dialog>
        OUR SERVICES
    </button>

    <div class="services-dialog-backdrop" data-services-dialog hidden>
        <div class="services-dialog" role="dialog" aria-modal="true" aria-labelledby="services-dialog-title">
            <div class="services-dialog-background" aria-hidden="true">
                <span class="dialog-orb dialog-orb-one"></span>
                <span class="dialog-orb dialog-orb-two"></span>
                <span class="dialog-orb dialog-orb-three"></span>
                <span class="dialog-spark dialog-spark-one"></span>
                <span class="dialog-spark dialog-spark-two"></span>
                <span class="dialog-spark dialog-spark-three"></span>
                <span class="dialog-spark dialog-spark-four"></span>
            </div>

            <button class="services-close" type="button" aria-label="Close services dialog" data-close-services-dialog>
                X
            </button>

            <div class="services-dialog-content">
                <h2 id="services-dialog-title">What Plantly AI Does</h2>

                <div class="services-grid">
                    <article class="service-card">
                        <h3>AI POST IDEAS</h3>
                        <p>
                            Generate fresh post angles for promotions, launches, seasonal moments, and daily engagement.
                            The system helps small businesses avoid repetitive content and keep ideas flowing every week.
                        </p>
                    </article>

                    <article class="service-card">
                        <h3>SOCIAL MEDIA CONTENT</h3>
                        <p>
                            Build captions, hashtags, and platform-ready content in a faster workflow. Plantly AI helps turn
                            a single idea into usable posts that still feel aligned with your brand voice.
                        </p>
                    </article>

                    <article class="service-card">
                        <h3>BRAND GROWING</h3>
                        <p>
                            Use AI-driven insights to spot what content themes are working and where your audience reacts most.
                            This makes it easier for growing businesses to stay consistent and improve visibility over time.
                        </p>
                    </article>

                    <article class="service-card">
                        <h3>CALENDAR/DASHBOARD</h3>
                        <p>
                            Manage campaigns, monthly plans, and posting schedules from one clear workspace. The dashboard is
                            built to keep your content organized while giving a fast overview of what is planned next.
                        </p>
                    </article>
                </div>
            </div>
        </div>
    </div>
</section>
